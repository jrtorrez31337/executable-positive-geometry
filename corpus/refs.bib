% --- Holographic bound & gravitational (von Neumann) algebras ---
% The algebraic sharpening of the holographic entropy bound: Bousso QFC/QNEC ->
% crossed-product Type III->II observable algebras -> generalized entropy = vN
% entropy. dS gets Type II_1 (max entropy = horizon area). 2403.09021 is the
% DSSYK bridge into Project-2. Filed 2026-07-11 (quant-phy), IDs verified by
% title against each PDF's first page.
@article{Bousso:2015mqa,
  author = {Bousso, Raphael and Fisher, Zachary and Leichenauer, Stefan and Wall, Aron C.},
  title = {A Quantum Focusing Conjecture},
  year = {2015}, eprint = {1506.02669}, archivePrefix = {arXiv},
  note = {QFC: generalized entropy is monotone under focusing. Its non-gravitational limit (QNEC) is a proven theorem in QFT; the QFC itself remains a conjecture. Root of the covariant-bound -> QES chain}
}
@article{Witten:2021unr,
  author = {Witten, Edward},
  title = {Gravity and the Crossed Product},
  year = {2022}, eprint = {2112.12828}, archivePrefix = {arXiv},
  note = {The crossed product of a Type III_1 QFT algebra with the modular flow yields a Type II algebra with a finite (renormalized) trace = generalized entropy. Founding paper of the Type II gravitational-algebra program}
}
@article{Faulkner:2024hjn,
